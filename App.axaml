<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OB.App"            
             xmlns:dialogHostAvalonia="using:DialogHostAvalonia"
             xmlns:converters="using:OB.Tools.Converters"
             xmlns:themes="clr-namespace:Material.Styles.Themes;assembly=Material.Styles"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <converters:BoolToSizeConverter x:Key="BoolToSizeConverter"/>
        <converters:BoolToAlignmentConverter x:Key="BoolToAlignmentConverter"/>
        <converters:BoolToMenuIconConverter x:Key="BoolToMenuIconConverter"/>
        <converters:ObjectEqualityConverter x:Key="ObjectEqualityConverter"/>
		<converters:BoolToMenuIconConverter x:Key="BoolToIconConverter"/>
    </Application.Resources>
  
    <Application.Styles>
        <themes:MaterialTheme BaseTheme="Dark" PrimaryColor="Indigo" SecondaryColor="Amber" />
		<StyleInclude Source="avares://DialogHost.Avalonia/Styles.xaml"/>
<materialIcons:MaterialIconStyles />
    </Application.Styles>
</Application>