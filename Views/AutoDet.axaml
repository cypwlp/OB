<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:md="clr-namespace:Material.Styles;assembly=Material.Styles"
             xmlns:micons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:vm="using:OB.ViewModels"
             mc:Ignorable="d" 
             d:DesignWidth="1200" 
             d:DesignHeight="720"
             x:Class="OB.Views.AutoDet"
             x:DataType="vm:AutoDetViewModel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- 工具列：用 Border + StackPanel 模擬 Top App Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialPrimaryColor}"
                Padding="16,8"
                BoxShadow="0 2 4 0 #1F000000">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            Spacing="12">
                    <!-- 載入按鈕 -->
                    <Button Classes="Filled"
                            Command="{Binding LoadImageCommand}"
                            MinWidth="160">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <micons:MaterialIcon Kind="FileUploadOutline" Width="20" Height="20"/>
                            <TextBlock Text="載入 PDF / 圖片" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Separator Width="1" Margin="8,0" Height="32" VerticalAlignment="Center"
                               Background="{DynamicResource MaterialOutlineColor}" />

                    <!-- 模式切換 -->
                    <ToggleButton Classes="Outlined"
                                  Command="{Binding SetRectModeCommand}"
                                  MinWidth="110">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <micons:MaterialIcon Kind="RectangleOutline" Width="20" Height="20"/>
                            <TextBlock Text="矩形" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <ToggleButton Classes="Outlined"
                                  Command="{Binding SetPolygonModeCommand}"
                                  MinWidth="110">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <micons:MaterialIcon Kind="VectorPolygon" Width="20" Height="20"/>
                            <TextBlock Text="多邊形" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ToggleButton>

                    <!-- 儲存 -->
                    <Button Classes="FilledTonal"
                            Command="{Binding SaveAnnotationsCommand}"
                            MinWidth="120">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <micons:MaterialIcon Kind="ContentSaveOutline" Width="20" Height="20"/>
                            <TextBlock Text="儲存標註" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 右側顯示目前模式文字 -->
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding ModeText}"
                           VerticalAlignment="Center"
                           FontWeight="Medium"
                           Margin="0,0,16,0"
                           Foreground="{DynamicResource MaterialPrimaryForegroundColor}"/>
            </DockPanel>
        </Border>

        <!-- 主要內容區域 -->
        <Grid Grid.Row="1" ColumnDefinitions="*, 280" Margin="16">

            <!-- 圖片工作區 (使用 Border 模擬 Card) -->
            <Border Grid.Column="0"
                    Classes="Card Elevation2"
                    CornerRadius="16"
                    ClipToBounds="True"
                    Background="{DynamicResource MaterialPaperColor}">
                <Grid>
                    <Image x:Name="ImageViewer"
                           Source="{Binding CurrentImage}"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
                    <Canvas x:Name="DrawingCanvas"
                            Background="Transparent"
                            PointerPressed="DrawingCanvas_PointerPressed"
                            PointerMoved="DrawingCanvas_PointerMoved"
                            PointerReleased="DrawingCanvas_PointerReleased"/>
                </Grid>
            </Border>

            <!-- 標註列表區域 (使用 Border 模擬 Card) -->
            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    Classes="Card Elevation3"
                    CornerRadius="16"
                    Padding="8"
                    Background="{DynamicResource MaterialPaperColor}">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0"
                               Text="標註列表"
                               Classes="Headline6"
                               Margin="16,12,16,8"/>
                    <ScrollViewer Grid.Row="1">
                        <ListBox ItemsSource="{Binding Annotations}"
                                 SelectedItem="{Binding SelectedAnnotation}"
                                 Margin="4">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="4"
                                            Padding="12,8"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource MaterialOutlineColor}"
                                            CornerRadius="8"
                                            Background="Transparent">
                                        <TextBlock Text="{Binding DisplayText}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 狀態列 -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialSurfaceVariantColor}"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource MaterialOutlineColor}"
                Padding="16,8">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource MaterialOnSurfaceVariantColor}"
                       FontSize="13"/>
        </Border>

    </Grid>
</UserControl>