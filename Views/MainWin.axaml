<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
        xmlns:controls="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
xmlns:i="using:Avalonia.Xaml.Interactivity"
xmlns:ia="using:Avalonia.Xaml.Interactions.Core"
        xmlns:vm="clr-namespace:OB.ViewModels"
        mc:Ignorable="d"
        d:DesignWidth="1200" d:DesignHeight="800"
        Title="MainWin"
        x:Class="OB.Views.MainWin"
        x:DataType="vm:MainViewModel"

        MinWidth="800" MinHeight="600">

    <!-- 根容器：DialogHost（用于全局对话框） -->
    <dialogHostAvalonia:DialogHost Identifier="MainDialogHost">
        <!-- SnackbarHost（用于全局提示） -->
        <controls:SnackbarHost HostName="Root">
            <!-- 左侧导航抽屉 -->
            <controls:NavigationDrawer LeftDrawerOpened="{Binding IsMenuExpanded, Mode=TwoWay}"
                                       Classes="permanent"
                                       LeftDrawerWidth="170"
                                       >
                <!-- 左侧抽屉内容：菜单 + 头部信息 -->
                <controls:NavigationDrawer.LeftDrawerContent >
                    <ScrollViewer Width="170">
                        <StackPanel Width="170">
                            <!-- 应用信息区域（图标、名称） -->
                            <controls:ColorZone Mode="Accent" Height="120">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image Width="64" Height="64"
                                           Source="avares://OB/Assets/app-icon.png"
                                           Margin="0,0,0,8" />
                                    <TextBlock Classes="Headline6" Text="OB 檢測系统"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </controls:ColorZone>

                            <!-- 菜单列表 -->
                            <ListBox ItemsSource="{Binding MenuItems}"
                                     SelectedItem="{Binding SelectedMenuItem, Mode=TwoWay}"
                                     Background="Transparent"

                                     Classes="NoScroll">
								<i:Interaction.Behaviors>
									<ia:EventTriggerBehavior EventName="SelectionChanged">
										<ia:InvokeCommandAction Command="{Binding SelectMenuItemCommand}"
																CommandParameter="{Binding SelectedMenuItem}" />
									</ia:EventTriggerBehavior>
								</i:Interaction.Behaviors>
                                <ListBox.Styles>
                                    <!-- 菜单项样式：高度48，垂直居中，内边距16 -->
                                    <Style Selector="ListBoxItem">
                                        <Setter Property="Height" Value="48" />
                                        <Setter Property="Padding" Value="16,0" />
                                        <Setter Property="VerticalContentAlignment" Value="Center" />
                                    </Style>
                                </ListBox.Styles>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left"
                                                    Spacing="16">
							
                                            <!-- 图标（使用 MaterialIcon） -->
                                            <avalonia:MaterialIcon Kind="{Binding Icon}" />
                                            <!-- 菜单标题 -->
                                            <TextBlock Text="{Binding Title}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </ScrollViewer>
                </controls:NavigationDrawer.LeftDrawerContent>

                <!-- 主内容区域（右侧） -->
                <DockPanel LastChildFill="True">
     
                    <!-- 顶部应用栏（AppBar） -->
                    <controls:ColorZone Mode="PrimaryMid"
                                         Height="56"
                                         DockPanel.Dock="Top"
                                         ZIndex="1">
                        <Grid Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- 汉堡菜单按钮（控制抽屉展开/折叠） -->
                            <ToggleButton Grid.Column="0"
                                          IsChecked="{Binding IsMenuExpanded, Mode=TwoWay}"
                                          Theme="{StaticResource MaterialFlatButton}"
                                          Width="32" Height="32" Padding="4">
                                <avalonia:MaterialIcon Kind="Menu" Width="24" Height="24" />
                            </ToggleButton>

                            <!-- 当前页面标题（可动态绑定） -->
                            <TextBlock Grid.Column="1"
                                       Classes="Headline6"
                                       Text="{Binding SelectedMenuItem.Title, FallbackValue='主页'}"
                                       VerticalAlignment="Center"
                                       Margin="16,0,0,0" />

                            <!-- 右侧用户菜单（示例） -->
                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Border Width="32" Height="32" CornerRadius="16"
                                        Background="Gray">
                                    <Image Source="avares://OB/Assets/avatar.png"
                                           Stretch="UniformToFill" />
                                </Border>
                                <TextBlock Text="{Binding LogUser.FullName }" VerticalAlignment="Center" />
                                <Button Theme="{StaticResource MaterialFlatButton}"
                                        Width="32" Height="32" Padding="4">
                                    <avalonia:MaterialIcon Kind="DotsVertical" Width="24" Height="24" />
                                </Button>
                            </StackPanel>
                        </Grid>
                    </controls:ColorZone>
                    <ContentControl prism:RegionManager.RegionName="MainRegion" />
                </DockPanel>
            </controls:NavigationDrawer>
        </controls:SnackbarHost>
    </dialogHostAvalonia:DialogHost>
</Window>