<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:dialogs="using:OB.ViewModels.Dialogs"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="520"
             xmlns:md="clr-namespace:Material.Styles.Controls;assembly=Material.Styles"
             x:DataType="dialogs:LoginViewModel"
             x:Class="OB.Views.Dialogs.Login">
	<Grid Background="#F8FAFC">
				<Canvas>
					<Ellipse Width="200" Height="200" Fill="#4F46E5" Opacity="0.05"
							 Canvas.Left="-50" Canvas.Top="-50"/>
					<Ellipse Width="300" Height="300" Fill="#10B981" Opacity="0.05"
							 Canvas.Left="600" Canvas.Top="300"/>
				</Canvas>
				<!-- 登錄卡片 -->
				<Border Width="400" Height="500"
						Background="White"
						CornerRadius="16"
						HorizontalAlignment="Center"
						VerticalAlignment="Center">
					<Grid Margin="40">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
						</Grid.RowDefinitions>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<!-- 應用圖標和標題 -->
						<StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,30" Grid.ColumnSpan="2" >
							<Border Width="64" Height="64"
									Background="#4F46E5"
									CornerRadius="32"
									Margin="0,0,0,10"/>
							<TextBlock Text="拓脈匙目標檢測系統"
									   FontSize="28"
									   FontWeight="Bold"
									   Foreground="#1E293B"
									   HorizontalAlignment="Center"/>
							<TextBlock Text="請輸入您的憑證登錄系統"
									   FontSize="14"
									   Foreground="#64748B"
									   HorizontalAlignment="Center"
									   Margin="0,5,0,0"/>
						</StackPanel>
						<!-- 用戶名輸入框 -->
						<StackPanel Grid.Row="1" Margin="0,0,0,20" Grid.ColumnSpan="2">
							<TextBlock Text="用戶名"
									   FontSize="13"
									   FontWeight="Medium"
									   Foreground="#475569"
									   Margin="0,0,0,5"/>
							<Border Background="#F1F5F9" CornerRadius="8" Padding="2">
								<TextBox Text="{Binding UserName, Mode=TwoWay}"
										 FontSize="14"
										 Background="Transparent"
										 BorderThickness="0"
										 Foreground="Black"
										 Padding="12">
									<TextBox.Styles>
										<Style Selector="TextBox:focus">
											<Setter Property="Background" Value="#FFFFFF"/>
											<Setter Property="BorderBrush" Value="#4F46E5"/>
											<Setter Property="BorderThickness" Value="2"/>
										</Style>
									</TextBox.Styles>
								</TextBox>
							</Border>
						</StackPanel>
						<!-- 密碼輸入框 -->
						<StackPanel Grid.Row="2" Margin="0,0,0,10" Grid.ColumnSpan="2">
							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="*"/>
									<ColumnDefinition Width="Auto"/>
								</Grid.ColumnDefinitions>
								<TextBlock Text="密碼"
										   FontSize="13"
										   FontWeight="Medium"
										   Foreground="#475569"
										   Margin="0,0,0,5"/>
								<TextBlock Grid.Column="1"
										   Text="忘記密碼？"
										   FontSize="12"
										   Foreground="#4F46E5"
										   VerticalAlignment="Center"
										   Cursor="Hand">
									<TextBlock.Styles>
										<Style Selector="TextBlock:pointerover">
											<Setter Property="Foreground" Value="#4338CA"/>
											<Setter Property="TextDecorations" Value="Underline"/>
										</Style>
									</TextBlock.Styles>
								</TextBlock>
							</Grid>
							<Border Background="#F1F5F9" CornerRadius="8" Padding="2">
								<TextBox Text="{Binding Password, Mode=TwoWay}"
										 FontSize="14"
										 Background="Transparent"
										 BorderThickness="0"
										 PasswordChar="*"
										 Foreground="Black"
										 Padding="12">
									<TextBox.Styles>
										<Style Selector="TextBox:focus">
											<Setter Property="Background" Value="#FFFFFF"/>
											<Setter Property="BorderBrush" Value="#4F46E5"/>
											<Setter Property="BorderThickness" Value="2"/>
										</Style>
									</TextBox.Styles>
								</TextBox>
							</Border>
						</StackPanel>
						<!-- 記住我選項 -->
						<CheckBox Grid.Row="3"
								  Content="記住我"
								  FontSize="13"
								  Foreground="#64748B"
								  Margin="0,0,0,30"/>
						<!-- 登錄按鈕 -->
						<Button Grid.Row="4"
								Grid.Column="0"
								Command="{Binding LoginCommand}"
								Content="登錄"
								FontSize="15"
								FontWeight="SemiBold"
								Foreground="White"
								Background="#4F46E5"
								BorderThickness="0"
								CornerRadius="8"
								Height="44"
								Cursor="Hand">
							<Button.Styles>
								<Style Selector="Button">
									<Setter Property="Opacity" Value="1"/>
								</Style>
								<Style Selector="Button:pointerover">
									<Setter Property="Background" Value="#4338CA"/>
									<Setter Property="Opacity" Value="0.9"/>
								</Style>
								<Style Selector="Button:pressed">
									<Setter Property="Background" Value="#3730A3"/>
									<Setter Property="Opacity" Value="0.8"/>
								</Style>
							</Button.Styles>
						</Button>
						<Button Grid.Row="4"
								Margin="20,0,0,0"
								Grid.Column="1"
								Command="{Binding ShowSetCommand}"
								Content="設置"
								FontSize="15"
								FontWeight="SemiBold"
								Foreground="White"
								Background="#4F46E5"
								BorderThickness="0"
								CornerRadius="8"
								Height="44"
								Cursor="Hand">
							<Button.Styles>
								<Style Selector="Button">
									<Setter Property="Opacity" Value="1"/>
								</Style>
								<Style Selector="Button:pointerover">
									<Setter Property="Background" Value="#4338CA"/>
									<Setter Property="Opacity" Value="0.9"/>
								</Style>
								<Style Selector="Button:pressed">
									<Setter Property="Background" Value="#3730A3"/>
									<Setter Property="Opacity" Value="0.8"/>
								</Style>
							</Button.Styles>
						</Button>
					</Grid>
				</Border>
	
	</Grid>
</UserControl>